<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
      Tracks whether the one-time welcome credit has been granted to a user.
      Set to NOW() inside the same transaction that credits the wallet, via a
      CAS-style UPDATE (`SET ... WHERE id=? AND welcome_credit_granted_at IS NULL`)
      so concurrent verify requests can't double-credit. Kept null for users
      who registered before this feature shipped — they will not retroactively
      receive the credit, since the only path that flips this column to NOW()
      is the email-verification handler.
    -->
    <changeSet id="v2026.04-add-welcome-credit-column" author="dev">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><columnExists tableName="users" columnName="welcome_credit_granted_at"/></not>
        </preConditions>
        <addColumn tableName="users">
            <column name="welcome_credit_granted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
