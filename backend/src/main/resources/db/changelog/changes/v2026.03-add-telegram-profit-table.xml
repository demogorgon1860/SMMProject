<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v2026.03-add-telegram-profit-table" author="dev">
        <comment>Create daily_profit_summary table for Telegram daily profit reports</comment>
        <createTable tableName="daily_profit_summary">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="report_date" type="DATE">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="total_profit" type="DECIMAL(12,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="completed_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="partial_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()"/>
        </createTable>
        <createIndex tableName="daily_profit_summary" indexName="idx_daily_profit_date">
            <column name="report_date" descending="true"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
