<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
      Stripe-style idempotency keys. Clients send `Idempotency-Key: <uuid>` on POSTs that
      could be retried by a flaky network (POST /v1/orders today; expandable to any other
      money-moving endpoint). The first request stores the result keyed by
      (user_id, idempotency_key, operation); duplicate requests within the TTL window
      return the stored result instead of re-executing.

      TTL window is enforced by the application (default 5 minutes) — an old request whose
      record has expired starts fresh, rather than indefinitely tying up the key. A periodic
      cleanup job removes rows past `expires_at` so the table stays small.

      Unique constraint on (user_id, idempotency_key, operation) is the gate: the second
      writer hits a constraint violation, which the service layer translates into "fetch the
      first writer's stored response and return it."
    -->
    <changeSet id="v2026.04-add-idempotency-keys" author="dev">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not><tableExists tableName="idempotency_keys"/></not>
        </preConditions>
        <createTable tableName="idempotency_keys">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- user_id: NOT NULL, no inline FK — the cascade rule is added below via
                 addForeignKeyConstraint so we can specify ON DELETE CASCADE. The `<column>`
                 shorthand `foreignKeyName="..."` syntax can't express ON DELETE behavior. -->
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="idempotency_key" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="operation" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <!-- Cached HTTP response for replay. Stored as TEXT (small JSON blob, no need for JSONB). -->
            <column name="response_status" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="response_body" type="TEXT"/>
            <!-- request_fingerprint: SHA-256 of the canonical request body. Lets us reject
                 the case where the same key is reused with a DIFFERENT body (Stripe semantics:
                 that is a client bug → 422, not a silent collision). -->
            <column name="request_fingerprint" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- One key per (user, operation). Insert race → constraint violation → service
             reads the existing row and returns the cached response. -->
        <addUniqueConstraint
                tableName="idempotency_keys"
                columnNames="user_id, idempotency_key, operation"
                constraintName="uq_idem_user_key_op"/>

        <!-- Cleanup job (deletes WHERE expires_at &lt; NOW()) needs an index to stay fast as
             the table grows. -->
        <createIndex tableName="idempotency_keys" indexName="idx_idem_expires_at">
            <column name="expires_at"/>
        </createIndex>

        <!-- ON DELETE CASCADE: when a user is hard-deleted (account-deletion scheduler), wipe
             their idempotency keys with them. The keys are short-lived (5-min TTL by default) and
             contain no compliance value — keeping them as orphan rows would just block the user
             delete with a NO ACTION FK violation. -->
        <addForeignKeyConstraint
                baseTableName="idempotency_keys"
                baseColumnNames="user_id"
                constraintName="fk_idem_user"
                referencedTableName="users"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="idempotency_keys"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
